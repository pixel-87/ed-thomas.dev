---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Now">
  <main class="max-w-4xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">
      <span class="text-[#5D3B8E] dark:text-[#cc6600]">*</span> now
    </h1>

    <section class="h-entry">
      <div class="prose prose-lg max-w-none e-content">
        <h2 class="text-lg font-semibold mt-4 mb-2">Currently working on:</h2>
        <ul class="list-dash list-outside space-y-2 pl-3 sm:pl-6">
          <li>Trying to get back into running and exercising</li>
          <li>Working on my dissertation still</li>
          <li>Came 2nd at a hackathon a little bit ago</li>
          <li>Job applications are killing me</li>
        </ul>
        <p class="text-sm muted mt-4">
          Last updated: <time class="dt-updated" datetime="2026-03-05">
            5th March, 2026</time>
        </p>
      </div>
    </section>
  </main>
</Layout>
